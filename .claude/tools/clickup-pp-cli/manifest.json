{
  "manifest_version": "0.3",
  "name": "clickup-pp-cli-pp-mcp",
  "display_name": "Clickup",
  "version": "4.9.0",
  "description": "Clickup API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/clickup-pp-cli-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/clickup-pp-cli-pp-mcp",
      "args": [],
      "env": {
        "CLICKUP_PP_CLI_BEARER_AUTH": "${user_config.clickup_pp_cli_bearer_auth}"
      }
    }
  },
  "user_config": {
    "clickup_pp_cli_bearer_auth": {
      "type": "string",
      "title": "CLICKUP_PP_CLI_BEARER_AUTH",
      "description": "Sets CLICKUP_PP_CLI_BEARER_AUTH for the Clickup MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
