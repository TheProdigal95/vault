		{"id":"bg-ashwagandha","type":"file","file":"IM8/00 Assets/Statics/energy-textured/backgrounds/bg-ashwagandha-root.png","x":11646,"y":4527,"width":223,"height":399},
		{"id":"bg-chanterelle","type":"file","file":"IM8/00 Assets/Statics/energy-textured/backgrounds/bg-chanterelle.png","x":11646,"y":4088,"width":223,"height":399},
