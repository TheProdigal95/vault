# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Claude Code plugin output (not part of the reach-digital workflow)
Agent Client/

# Hermes tool SOURCE is tracked — the slash commands depend on it, so a fresh
# clone MUST include it. Ignore only heavy regenerable data and large generated
# renders. (node_modules/ and .env are already ignored above; .env.example
# templates ARE tracked so a new machine can scaffold its own .env.)
00 Global/Hermes/tools/**/data/
00 Global/Hermes/tools/**/downloads/
00 Global/Hermes/tools/**/renders/

# OS metadata
._*
.fseventsd
.DocumentRevisions-V100
.com.apple.timemachine.donotpresent

# Deploy artifacts (the deploy/ scripts themselves ARE committed; this is for
# any future generated deploy state like .terraform/, .kube/, etc.)
deploy/.terraform/
deploy/.kube/
